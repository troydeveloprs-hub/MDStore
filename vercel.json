{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/brand/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/((?!api|Pages|collections|css|js|data|img|imghero|logos|scratch|supabase|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
